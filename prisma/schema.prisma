//   isActive   Boolean  @default(true)
//   deletedAt  DateTime?
// }


model Doctor {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  specialization String
  schedule       Json            // Store weekly schedule
  dailyQuota     Int             @default(20) // Max patients per day
  consultationFee Float          @default(50000) // Biaya konsultasi per dokter
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  certificates   MedicalCertificate[]

  @@map("doctors")
}

model Medicine {
  id          String         @id @default(cuid())
  name        String
  category    String?        // e.g., Tablet, Sirup, Salep
  stock       Int            @default(0)
  price       Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  prescriptions Prescription[]

  @@map("medicines")
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  queueNumber     Int
  appointmentDate DateTime
  timeSlot        String
  status          AppointmentStatus @default(WAITING)
  qrCode          String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor          Doctor            @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  medicalRecord   MedicalRecord?
  payment         Payment?

  @@index([doctorId, appointmentDate])
  @@index([patientId])
  @@index([status])
  @@index([appointmentDate])
  @@map("appointments")
}

model MedicalRecord {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String   @unique
  complaint     String
  diagnosis     String
  treatment     String
  notes         String?
  vitalSigns    Json?    // { bloodPressure, heartRate, temperature, weight, height }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor        Doctor       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  appointment   Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  prescriptions Prescription[]
  certificate   MedicalCertificate?

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
  @@map("medical_records")
}

model Prescription {
  id              String             @id @default(cuid())
  medicalRecordId String
  medicineId      String?            // Optional for backwards compatibility
  medicationName  String
  dosage          String
  instructions    String
  quantity        Int                @default(1)
  unitPrice       Float              @default(0) // snapshot harga saat dispense
  status          PrescriptionStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  medicalRecord   MedicalRecord      @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  medicine        Medicine?          @relation(fields: [medicineId], references: [id], onDelete: SetNull)

  @@index([medicalRecordId])
  @@index([status])
  @@map("prescriptions")
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  invoiceNumber String        @unique
  totalAmount   Float
  status        PaymentStatus @default(PENDING)
  paymentMethod String?       // CASH, TRANSFER
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([paidAt])
  @@index([createdAt])
  @@map("payments")
}

model MedicalCertificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  medicalRecordId   String   @unique
  doctorId          String
  patientId         String
  patientName       String
  patientNik        String
  restDays          Int
  startDate         DateTime
  endDate           DateTime
  diagnosis         String
  notes             String?
  issuedAt          DateTime @default(now())

  medicalRecord     MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  doctor            Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("medical_certificates")
}

model ClinicSettings {
  id                    String   @id @default(cuid())
  clinicName            String   @default("KlinikCare")
  address               String?
  phone                 String?
  email                 String?
  logo                  String?
  operatingHours        Json     // { open: "08:00", close: "17:00", days: ["monday","tuesday","wednesday","thursday","friday","saturday"] }
  consultationFeeDefault Float  @default(50000)
  updatedAt             DateTime @updatedAt

  @@map("clinic_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g., "VIEW_RECORD", "CREATE_RECORD", "UPDATE_RECORD"
  entity    String   // e.g., "MedicalRecord", "Patient"
  entityId  String
  details   String?  // Additional context
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
